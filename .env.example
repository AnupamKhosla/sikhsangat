# Copy this file to .env and fill in real values. .env is gitignored.
#
# Protected remote fetch fallback for pages the origin refuses from our IP.
# Compatible endpoints (all speak: GET <endpoint>?url=<target> with Authorization: Bearer <token>):
#   - https://crimewiki.site/proxy.php   (the PHP proxy in the crimeWiki repo)
#   - https://<your-vercel>.vercel.app/api/fetch  (the sibling proxies repo)
#
# Leave these empty to disable the fallback — the scraper still runs, just without the
# second network path.
SCRAPER_REMOTE_FETCH_ENDPOINT=
SCRAPER_REMOTE_FETCH_TOKEN=

# Optional: override the 45s default.
# SCRAPER_REMOTE_FETCH_TIMEOUT_MS=45000
